# Required: gateway bearer token used in Authorization header
GOCLAW_GATEWAY_TOKEN=

# Optional: GoClaw HTTP gateway base URL (defaults to http://localhost:18790)
GOCLAW_BASE_URL=http://localhost:18790

# Optional: value for the X-GoClaw-User-Id header (defaults to "system")
GOCLAW_USER_ID=system

# Optional: directory where pulled tenants/agents are written (defaults to ./tenants)
GOCLAW_OUTPUT_DIR=tenants
