{
  "name": "goclaw-config",
  "version": "0.1.0",
  "description": "CLI to pull and push GoClaw configurations via REST API",
  "type": "module",
  "private": true,
  "bin": {
    "goclaw-config": "./src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "pull": "bun run src/index.ts pull",
    "push": "bun run src/index.ts push",
    "typecheck": "bun tsc --noEmit"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.3"
  }
}
